            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{reader_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"post_id\": {{post_id}},\n  \"parent_id\": {{reply_id}},\n  \"content\": \"Reply to reply\"\n}" },
            "url": "{{host}}/comment"
          }
        },
        {
          "name": "FALSE - Create comment invalid post",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(422);", "pm.expect(pm.response.json().status).to.eql(false);"] } }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{reader_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"post_id\": 999999,\n  \"content\": \"Invalid post comment\"\n}" },
            "url": "{{host}}/comment"
          }
        }
      ]
    },
    {
      "name": "06 Like",
      "item": [
        {
          "name": "TRUE - Like post",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(200);", "const json = pm.response.json();", "pm.expect(json.status).to.eql(true);", "pm.expect(json.data.liked).to.eql(true);"] } }],
          "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{reader_token}}" }], "url": "{{host}}/like/toggle/{{post_id}}" }
        },
        {
          "name": "TRUE - Unlike post",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(200);", "const json = pm.response.json();", "pm.expect(json.status).to.eql(true);", "pm.expect(json.data.liked).to.eql(false);"] } }],
          "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{reader_token}}" }], "url": "{{host}}/like/toggle/{{post_id}}" }
        },
        {
          "name": "FALSE - Toggle like without token",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(401);"] } }],
          "request": { "method": "POST", "header": [], "url": "{{host}}/like/toggle/{{post_id}}" }
        }
      ]
    },
    {
      "name": "07 Trash And Delete",
      "item": [
        {
          "name": "TRUE - Soft delete own post",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(200);", "pm.expect(pm.response.json().status).to.eql(true);"] } }],
          "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{author_token}}" }], "url": "{{host}}/post/{{post_id}}" }
        },
        {
          "name": "TRUE - List trash authenticated",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(200);", "pm.expect(pm.response.json().status).to.eql(true);", "pm.expect(pm.response.json()).to.have.property('_meta');"] } }],
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{author_token}}" }], "url": "{{host}}/post/trash?page=1&limit=10" }
        },
        {
          "name": "TRUE - Restore own post",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(200);", "pm.expect(pm.response.json().status).to.eql(true);"] } }],
          "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{author_token}}" }], "url": "{{host}}/post/{{post_id}}/restore" }
        },
        {
          "name": "FALSE - Delete post without token",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(401);"] } }],
          "request": { "method": "DELETE", "header": [], "url": "{{host}}/post/{{post_id}}" }
        }
      ]
    }
  ]
}
